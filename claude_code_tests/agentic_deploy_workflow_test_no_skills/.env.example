# Copy to .env and tweak. Source before running scripts: `set -a; source .env; set +a`

AWS_PROFILE=HF-Sandbox-access-754289655784
# AWS_REGION is intentionally NOT set here. If left unset, scripts read it from
# the profile's `region` setting in ~/.aws/config (currently eu-north-1).
# Uncomment + set this to override.
# AWS_REGION=eu-north-1

HF_MODEL_ID=Qwen/Qwen3-0.6B
INSTANCE_TYPE=ml.g5.xlarge
ENDPOINT_NAME=qwen3-06b-endpoint

# vLLM SageMaker DLC tag. 0.21.0 / cu130 / sagemaker-v1.4 was the latest stable
# tag as of 2026-05. Full image URI is composed at deploy time as:
#   763104351884.dkr.ecr.<region>.amazonaws.com/vllm:<VLLM_IMAGE_TAG>
VLLM_IMAGE_TAG=0.21.0-gpu-py312-cu130-ubuntu22.04-sagemaker-v1.4

# Host AMI version. CUDA-13 vLLM images need the 3-1 (or newer) inference AMI;
# the default older AMI causes container/host driver mismatches.
INFERENCE_AMI_VERSION=al2-ami-sagemaker-inference-gpu-3-1

# vLLM serving knobs (mapped to vLLM CLI args by the SM_VLLM_ env-var prefix).
# Conservative ceiling on a single A10G's KV-cache budget; Qwen3-0.6B's native
# context is larger but we don't need it for a smoke-test endpoint.
MAX_MODEL_LEN=4096
TENSOR_PARALLEL_SIZE=1

# Optional resource names — defaults are derived from ENDPOINT_NAME.
# MODEL_NAME=qwen3-06b-endpoint-model
# ENDPOINT_CONFIG_NAME=qwen3-06b-endpoint-config

# IAM role for SageMaker. The default ROLE_NAME=sagemaker-huggingface is an
# existing role in this account; 01-ensure-role.sh just resolves its ARN.
# ROLE_NAME=sagemaker-huggingface
# SAGEMAKER_ROLE_ARN=arn:aws:iam::754289655784:role/sagemaker-huggingface

# Only required if you swap to a gated HF model. Qwen3-0.6B is open.
# HF_TOKEN=hf_xxx
